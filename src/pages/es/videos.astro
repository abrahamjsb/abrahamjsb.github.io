---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Abraham Sanchez - Videos" lang="es">
  <div class="max-w-4xl mx-auto space-y-12">
    <header class="space-y-4 text-center md:text-left">
      <h1 class="text-4xl font-bold tracking-tight">Videos</h1>
      <p class="text-[var(--muted-color)] text-lg max-w-2xl">
        El futuro hogar de mi canal de YouTube. Espera tutoriales, análisis técnicos a fondo 
        y discusiones sobre cómo llevar una vida con propósito como ingeniero.
      </p>
    </header>

    <div class="bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-xl p-12 text-center shadow-inner">
      <div class="text-6xl mb-6">🎬</div>
      <h2 class="text-2xl font-semibold mb-4">Lanzamiento Próximamente</h2>
      <p class="text-[var(--muted-color)] max-w-md mx-auto mb-8">
        Actualmente estoy preparando el estudio y grabando mi primera serie de videos. 
        ¡Mantente al tanto!
      </p>
      <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-6 py-3 rounded-md bg-[#ff0000] hover:bg-[#cc0000] text-white font-medium transition-colors shadow-lg">
        Suscríbete en YouTube
      </a>
    </div>
  </div>
</BaseLayout>
