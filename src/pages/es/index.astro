---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Abraham Sanchez - Bienvenido" lang="es">
  <section
    class="mt-8 md:mt-16 flex flex-col items-center text-center space-y-6"
  >
    <div
      class="w-32 h-38 md:w-40 md:h-47 mb-4"
      role="img"
      aria-label="Abraham Sanchez Logo"
      style="background-color: var(--text-color); -webkit-mask-image: url('/logo.svg'); mask-image: url('/logo.svg'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;"
    >
    </div>

    <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
      Abraham Sanchez
    </h1>
    <h2
      class="text-xl md:text-2xl text-[var(--color-primary)] font-medium max-w-2xl"
    >
      Ingeniero de Software y Creador Digital
    </h2>

    <div class="flex gap-4 justify-center items-center">
      <a
        href="https://github.com/abrahamjsb"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--muted-color)] hover:text-[var(--color-primary)] transition-colors p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800"
        aria-label="Perfil de GitHub"
      >
        <svg
          class="w-6 h-6"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            clip-rule="evenodd"></path>
        </svg>
      </a>
      <a
        href="https://www.linkedin.com/in/abraham-sanchez-782309b7/"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--muted-color)] hover:text-[var(--color-primary)] transition-colors p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800"
        aria-label="Perfil de LinkedIn"
      >
        <svg
          class="w-6 h-6"
          fill="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
      </a>
    </div>
    <p class="text-lg text-[var(--muted-color)] max-w-2xl leading-relaxed mt-4">
      Bienvenido a mi rincón personal en la web. Este sitio esta actualmente en
      construcción. Aquí compartiré principios estoicos para una vida plena y
      documentaré mi viaje.
    </p>

    <div
      class="mt-10 flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center"
    >
      <a
        href="mailto:as.venturesg@gmail.com"
        class="px-8 py-3 rounded-md bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-medium transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5"
      >
        Contáctame
      </a>
      <a
        href="/es/blog/"
        class="px-8 py-3 rounded-md border-2 border-[var(--text-color)] text-[var(--text-color)] hover:bg-[var(--text-color)] hover:text-[var(--bg-color)] font-medium transition-all"
      >
        Lee mi Blog
      </a>
    </div>
  </section>

  <section class="mt-24 border-t border-gray-100 dark:border-gray-800 pt-16">
    <div class="grid md:grid-cols-2 gap-12">
      <div class="space-y-6">
        <h3 class="text-2xl font-semibold flex items-center gap-2">
          <span>📝</span> Escritos Recientes
        </h3>
        <p class="text-[var(--muted-color)]">
          Explora mis últimos artículos sobre desarrollo de software y
          estoicismo.
        </p>
        <a
          href="/es/blog/"
          class="inline-block text-[var(--color-primary)] hover:underline font-medium"
          >Ver todas las publicaciones &rarr;</a
        >
      </div>

      <div class="space-y-6">
        <h3 class="text-2xl font-semibold flex items-center gap-2">
          <span>🎥</span> Últimos Videos
        </h3>
        <p class="text-[var(--muted-color)]">
          Mira mi contenido más reciente sobre tecnología, ideas y crecimiento
          personal.
        </p>
        <a
          href="/es/videos/"
          class="inline-block text-[var(--color-primary)] hover:underline font-medium"
          >Ver videos &rarr;</a
        >
      </div>
    </div>
  </section>
</BaseLayout>
