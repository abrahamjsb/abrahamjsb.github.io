---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Abraham Sanchez - Bienvenido" lang="es">
  <section class="mt-8 md:mt-16 flex flex-col items-center text-center space-y-6">
    <div class="w-32 h-32 md:w-40 md:h-40 rounded-full bg-gray-200 dark:bg-gray-800 flex items-center justify-center overflow-hidden mb-4 shadow-xl shadow-[var(--color-primary)]/20">
      <img src="/logo.png" alt="Abraham Sanchez Avatar" class="w-full h-full object-cover" />
    </div>
    
    <h1 class="text-4xl md:text-5xl font-bold tracking-tight">Abraham Sanchez</h1>
    <h2 class="text-xl md:text-2xl text-[var(--color-primary)] font-medium max-w-2xl">
      Ingeniero de Software y Creador Digital
    </h2>
    <p class="text-lg text-[var(--muted-color)] max-w-2xl leading-relaxed mt-4">
      Bienvenido a mi rincón personal en la web. Aquí escribo sobre tecnología, 
      comparto principios estoicos para una vida plena y documento mi viaje.
    </p>

    <div class="mt-10 flex flex-col sm:flex-row gap-4 w-full sm:w-auto justify-center">
      <a href="mailto:contact@example.com" class="px-8 py-3 rounded-md bg-[var(--color-primary)] hover:bg-[var(--color-primary-dark)] text-white font-medium transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5">
        Contáctame
      </a>
      <a href="/es/blog/" class="px-8 py-3 rounded-md border-2 border-[var(--text-color)] text-[var(--text-color)] hover:bg-[var(--text-color)] hover:text-[var(--bg-color)] font-medium transition-all">
        Lee mi Blog
      </a>
    </div>
  </section>

  <section class="mt-24 border-t border-gray-100 dark:border-gray-800 pt-16">
    <div class="grid md:grid-cols-2 gap-12">
      <div class="space-y-6">
        <h3 class="text-2xl font-semibold flex items-center gap-2">
          <span>📝</span> Escritos Recientes
        </h3>
        <p class="text-[var(--muted-color)]">
          Explora mis últimos artículos sobre desarrollo de software y estoicismo.
        </p>
        <a href="/es/blog/" class="inline-block text-[var(--color-primary)] hover:underline font-medium">Ver todas las publicaciones &rarr;</a>
      </div>
      
      <div class="space-y-6">
        <h3 class="text-2xl font-semibold flex items-center gap-2">
          <span>🎥</span> Últimos Videos
        </h3>
        <p class="text-[var(--muted-color)]">
          Mira mi contenido más reciente sobre tecnología, ideas y crecimiento personal.
        </p>
        <a href="/es/videos/" class="inline-block text-[var(--color-primary)] hover:underline font-medium">Ver videos &rarr;</a>
      </div>
    </div>
  </section>
</BaseLayout>
