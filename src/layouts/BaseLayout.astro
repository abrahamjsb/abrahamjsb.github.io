---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  lang?: "en" | "es";
}

const {
  title,
  description = "Abraham Sanchez - Professional Site",
  lang = "en",
} = Astro.props;

// Helper variables for layout translations
const t = {
  en: {
    home: "Home",
    blog: "Blog",
    videos: "Videos",
    contact: "Contact",
    toggleTheme: "Toggle Theme",
    toggleLang: "ES",
    langUrl: "/es",
  },
  es: {
    home: "Inicio",
    blog: "Blog",
    videos: "Videos",
    contact: "Contacto",
    toggleTheme: "Cambiar Tema",
    toggleLang: "EN",
    langUrl: "/en",
  },
};

const nav = t[lang];
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicons/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicons/favicon.ico" />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicons/favicon-16x16.png"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicons/favicon-32x32.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicons/apple-touch-icon.png"
    />
    <title>{title}</title>
    <script is:inline>
      // Inline script to prevent FOUC for dark mode
      const getPreferredTheme = () => {
        if (
          typeof localStorage !== "undefined" &&
          localStorage.getItem("theme")
        ) {
          return localStorage.getItem("theme");
        }
        return window.matchMedia("(prefers-color-scheme: dark)").matches
          ? "dark"
          : "light";
      };

      const setTheme = (theme) => {
        if (theme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      };

      setTheme(getPreferredTheme());

      // Listen for OS theme changes dynamically
      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", (e) => {
          // Only update automatically if the user hasn't explicitly overridden the theme
          if (
            typeof localStorage !== "undefined" &&
            !localStorage.getItem("theme")
          ) {
            setTheme(e.matches ? "dark" : "light");
          }
        });
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <header
      class="py-6 px-4 md:px-8 border-b border-gray-200 dark:border-gray-800 flex justify-between items-center"
    >
      <div>
        <a
          href={`/${lang}/`}
          class="text-xl font-semibold hover:text-[var(--color-primary)] transition-colors"
          >Abraham Sanchez</a
        >
      </div>
      <nav class="flex items-center gap-6">
        <a
          href={`/${lang}/blog/`}
          class="text-muted-color hover:text-[var(--color-primary)] transition-colors"
          >{nav.blog}</a
        >
        <a
          href={`/${lang}/videos/`}
          class="text-muted-color hover:text-[var(--color-primary)] transition-colors"
          >{nav.videos}</a
        >

        <div
          class="flex items-center gap-4 ml-4 pl-4 border-l border-gray-300 dark:border-gray-700"
        >
          <button
            id="theme-toggle"
            aria-label={nav.toggleTheme}
            class="text-muted-color hover:text-text-color transition-colors"
          >
            <!-- Sun Icon (shows in dark mode) -->
            <svg
              class="w-5 h-5 hidden dark:block"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"
              ></path>
            </svg>
            <!-- Moon Icon (shows in light mode) -->
            <svg
              class="w-5 h-5 block dark:hidden"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"
              ></path>
            </svg>
          </button>
          <a
            href={nav.langUrl}
            class="text-sm font-medium px-2 py-1 rounded bg-gray-100 dark:bg-gray-800 text-muted-color hover:text-text-color transition-colors"
          >
            {nav.toggleLang}
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-grow max-w-4xl w-full mx-auto px-4 py-12">
      <slot />
    </main>

    <footer
      class="py-12 mt-12 text-center text-sm text-[var(--muted-color)] border-t border-gray-200 dark:border-gray-800"
    >
      <div class="flex justify-center gap-6 mb-6">
        <a
          href="https://www.linkedin.com/in/abraham-sanchez-782309b7/"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-primary)] transition-colors flex items-center gap-2"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          LinkedIn
        </a>
        <a
          href="https://github.com/abrahamjsb"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-[var(--color-primary)] transition-colors flex items-center gap-2"
        >
          <svg
            class="w-5 h-5"
            fill="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              fill-rule="evenodd"
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
              clip-rule="evenodd"></path>
          </svg>
          GitHub
        </a>
      </div>
      <p>
        &copy; {new Date().getFullYear()} Abraham Sanchez. {
          lang === "es"
            ? "Todos los derechos reservados."
            : "All rights reserved."
        }
      </p>
    </footer>

    <script is:inline>
      const handleToggleClick = () => {
        const element = document.documentElement;
        element.classList.toggle("dark");

        const isDark = element.classList.contains("dark");
        localStorage.setItem("theme", isDark ? "dark" : "light");
      };
      document
        .getElementById("theme-toggle")
        ?.addEventListener("click", handleToggleClick);
    </script>
  </body>
</html>
